import <wdoc.wcl>
use wdoc::{page, layout, heading, paragraph, code, data_table, callout, bold, italic, link}

page cli_eval {
    section = "wcl_docs.cli.cli_eval"
    title = "wcl eval"

    layout {
        vsplit v1 {
            split s1 {
                size = 100

                heading h1 {
                    level = 1
                    content = "wcl eval"
                }

                paragraph p1 {
                    content = "Evaluate a WCL document and print the resolved output. Optionally project the result through a WCL expression."
                }

                heading h2_usage {
                    level = 2
                    content = "Usage"
                }

                code c1 {
                    language = "bash"
                    content = "wcl eval <file> [expression] [options]"
                }

                heading h2_options {
                    level = 2
                    content = "Options"
                }

                data_table t1 {
                    caption = "Arguments and Options"
                    rows = [
                        { flag = "<file>", description = "Input WCL file" },
                        { flag = "[expression]", description = "Optional WCL expression to evaluate against the document" },
                        { flag = "--format <fmt>", description = "Output format: wcl or json (default: wcl)" },
                        { flag = "--var KEY=VALUE", description = "Set an external variable (may be repeated)" },
                        { flag = "--lib-path <dir>", description = "Extra library search path (may be repeated)" },
                        { flag = "--no-default-lib-paths", description = "Disable default XDG/system library search paths" }
                    ]
                }

                heading h2_description {
                    level = 2
                    content = "Description"
                }

                paragraph p2 {
                    content = "<code>wcl eval</code> runs the full evaluation pipeline — macros expanded, expressions evaluated, imports merged, partial blocks resolved — and prints the final resolved document."
                }

                paragraph p3 {
                    content = "When an <code>expression</code> is supplied, it is parsed as a WCL expression and evaluated in the document's scope. This lets you read specific values, call functions, and project the document into whatever shape you need. Define helper functions in the file (or a library) and call them as the expression to produce custom projections."
                }

                paragraph p4 {
                    content = "Default output is WCL. Pass <code>--format json</code> for JSON output. For YAML, TOML, or other formats, pipe through " + link("wcl transform", "cli_transform.html") + "."
                }

                heading h2_examples {
                    level = 2
                    content = "Examples"
                }

                paragraph p5 {
                    content = "Evaluate the whole document (WCL output):"
                }

                code c2 {
                    language = "bash"
                    content = "wcl eval config.wcl"
                }

                paragraph p6 {
                    content = "Evaluate as JSON:"
                }

                code c3 {
                    language = "bash"
                    content = "wcl eval config.wcl --format json"
                }

                paragraph p7 {
                    content = "Read a single value via an expression:"
                }

                code c4 {
                    language = "bash"
                    content = "wcl eval config.wcl 'services[0].port'"
                }

                paragraph p8 {
                    content = "Project the document through a helper function defined in the file:"
                }

                code c5 {
                    language = "wcl"
                    content = <<-'WCL'
                    // config.wcl
                    let services = [
                        { name = "api", port = 8080 },
                        { name = "web", port = 8081 }
                    ]

                    let summary = () => map(services, (s) => s.name)
                    WCL
                }

                code c6 {
                    language = "bash"
                    content = "wcl eval config.wcl 'summary()' --format json"
                }

                paragraph p9 {
                    content = "Override variables:"
                }

                code c7 {
                    language = "bash"
                    content = "wcl eval --var PORT=8080 --var DEBUG=true config.wcl"
                }

                paragraph p10 {
                    content = "Pipe JSON output to another tool:"
                }

                code c8 {
                    language = "bash"
                    content = "wcl eval config.wcl --format json | jq '.service'"
                }
            }
        }
    }
}
