{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "WCL",
  "scopeName": "source.wcl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#decorators" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.wcl",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.wcl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.wcl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.wcl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wcl",
              "match": "\\\\[\"\\\\nrt]"
            },
            {
              "name": "meta.embedded.expression.wcl",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.wcl" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.wcl" }
              },
              "patterns": [
                { "include": "source.wcl" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.wcl",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.wcl",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.wcl",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.wcl",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.wcl",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.wcl",
          "match": "\\b(if|else|for|in|when)\\b"
        },
        {
          "name": "keyword.declaration.wcl",
          "match": "\\b(let|partial|macro|schema|table|validation|decorator_schema)\\b"
        },
        {
          "name": "keyword.other.wcl",
          "match": "\\b(import|export|inject|set|remove|self|query|ref)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.wcl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.wcl",
          "match": "\\bnull\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.wcl",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.wcl",
          "match": "\\b(string|int|float|bool|identifier|any|list|map|set|union)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.wcl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.wcl",
          "match": "(==|!=|<=|>=|<|>|=~)"
        },
        {
          "name": "keyword.operator.logical.wcl",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.wcl",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.wcl",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arrow.wcl",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipe.wcl",
          "match": "\\|"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.wcl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
        }
      ]
    }
  }
}
