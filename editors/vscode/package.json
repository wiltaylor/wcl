{
  "name": "wcl",
  "displayName": "WCL - Wil's Configuration Language",
  "description": "Syntax highlighting, diagnostics, hover, completions, go-to-definition, formatting, and more for WCL (Wil's Configuration Language). Includes a bundled LSP server.",
  "version": "0.0.0-local",
  "publisher": "wil",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:wcl"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wcl",
        "aliases": [
          "WCL",
          "wcl"
        ],
        "extensions": [
          ".wcl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wcl",
        "scopeName": "source.wcl",
        "path": "./syntaxes/wcl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "WCL",
      "properties": {
        "wcl.server.path": {
          "type": "string",
          "default": "wcl",
          "description": "Path to the wcl binary"
        },
        "wcl.server.args": {
          "type": "array",
          "default": [
            "lsp"
          ],
          "description": "Arguments passed to the wcl binary to start the LSP server"
        }
      }
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["wcl", "configuration", "language", "lsp"],
  "author": "Wil Taylor",
  "homepage": "https://wcl.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiltaylor/wcl"
  },
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
