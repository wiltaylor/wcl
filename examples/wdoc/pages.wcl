// Pages for the WCL documentation example

import <wdoc.wcl>

// Helper: literal dollar sign for code examples containing ${...}
let D = "$"

// ── Overview page ──

wdoc_page overview {
    section = "my_docs.getting_started.overview"
    title = "Overview"

    wdoc_layout {
        vsplit v1 {
            split s1 {
                size = 100

                image hero_img {
                    src = "images/hero-banner.png"
                    alt = "WCL Documentation"
                }

                @style("hero")
                heading h1 {
                    level = 1
                    content = "WCL - Wils Configuration Language"
                }

                @style("hero")
                paragraph p1 {
                    content = "A typed, block-structured configuration language with schemas, validation, and powerful expressions."
                }

                heading h2 {
                    level = 2
                    content = "Why WCL?"
                }

                paragraph p2 {
                    content = "WCL brings the " + bold("safety of typed schemas") + " and the " + bold("flexibility of expressions") + " to configuration files. No more YAML indentation bugs or JSON without comments."
                }

                callout welcome {
                    icon = "check-circle"
                    header = "Ready to go"
                    color = "#28a745"
                    paragraph w_p1 { content = "WCL is installed and ready. Explore the examples below to see what it can do." }
                }

                heading h3a {
                    level = 3
                    content = "Quick Example"
                }

                paragraph p3 {
                    content = "Here is a complete WCL configuration with schemas, variables, control flow, and validation:"
                }

                code c1 {
                    language = "wcl"
                    content = "// Define the structure\nschema \"server\" {\n    host: string\n    port: i64 @validate(min = 1, max = 65535)\n    workers: i64 @validate(min = 1, max = 32)\n    tls: bool @optional\n    region: string @optional\n}\n\n// Variables and expressions\nlet environment = \"production\"\nlet base_port = 8000\nlet is_prod = environment == \"production\"\nlet regions = [\"us-east\", \"eu-west\", \"ap-south\"]\n\n// Static blocks\nserver api {\n    host = \"0.0.0.0\"\n    port = base_port + 80\n    workers = is_prod ? 8 : 2\n    tls = is_prod\n}\n\n// Dynamic blocks with control flow\nfor region in regions {\n    server worker-" + D + "{region} {\n        host = \"" + D + "{region}.internal\"\n        port = base_port + 2000\n        workers = 4\n        region = region\n    }\n}\n\n// Data tables\ntable users {\n    name:  string\n    role:  string\n    admin: bool\n    | \"alice\" | \"engineering\" | true  |\n    | \"bob\"   | \"marketing\"  | false |\n    | \"carol\" | \"engineering\" | true  |\n}\n\n// Validation\nvalidation \"port uniqueness\" {\n    let ports = query(server | .port)\n    check = len(distinct(ports)) == len(ports)\n    message = \"All server ports must be unique\"\n}"
                }

                heading h3b {
                    level = 3
                    content = "Key Features"
                }

                paragraph p4 { content = icon("shield-check", "1.1em", "#28a745") + " " + bold("Typed schemas") + " - define and validate your configuration structure at parse time." }
                paragraph p5 { content = icon("code-slash", "1.1em", "var(--color-link)") + " " + bold("Expressions") + " - variables, conditionals, loops, string interpolation, and 45+ built-in functions." }
                paragraph p6 { content = icon("table", "1.1em", "#6f42c1") + " " + bold("Tables") + " - structured tabular data with typed columns and CSV import." }
                paragraph p7 { content = icon("box-arrow-in-right", "1.1em", "#fd7e14") + " " + bold("Imports and Libraries") + " - modular configuration with library support and glob imports." }
                paragraph p8 { content = icon("filetype-json", "1.1em", "#e83e8c") + " " + bold("Multiple output formats") + " - evaluate to JSON, YAML, TOML, or MessagePack." }
                paragraph p9 { content = icon("brush", "1.1em", "#17a2b8") + " " + bold("Diagrams and Shapes") + " - vector diagrams with shapes, connections, and graph layouts." }
                paragraph p10 { content = icon("palette", "1.1em", "#6610f2") + " " + bold("Dark mode") + " - system detection with manual toggle, theme-aware throughout." }
            }
        }
    }
}

// ── Installation page ──

wdoc_page install {
    section = "my_docs.getting_started.installation"
    title = "Installation"

    wdoc_layout {
        vsplit v2 {
            split s2 {
                size = 70

                heading h1 {
                    level = 1
                    content = "Installation"
                }

                paragraph p1 {
                    content = "Install WCL using one of the methods below. Pre-built binaries are available for Linux, macOS, and Windows."
                }

                heading h2a {
                    level = 2
                    content = "From Source (Rust)"
                }
                code c1 {
                    language = "bash"
                    content = "# Install from crates.io\ncargo install wcl\n\n# Or build from source\ngit clone https://github.com/wiltaylor/wcl\ncd wcl\ncargo install --path crates/wcl"
                }

                heading h2b {
                    level = 2
                    content = "Python Bindings"
                }
                code c2 {
                    language = "bash"
                    content = "pip install pywcl"
                }

                heading h2c {
                    level = 2
                    content = ".NET Bindings"
                }
                code c3 {
                    language = "bash"
                    content = "dotnet add package WclLang"
                }

                heading h2d {
                    level = 2
                    content = "Verify Installation"
                }
                code c4 {
                    language = "bash"
                    content = "$ wcl --version\nwcl 0.2.4\n\n$ echo 'server api { host = \"0.0.0.0\" }' | wcl eval /dev/stdin --format json\n{\n  \"server\": {\n    \"api\": {\n      \"host\": \"0.0.0.0\"\n    }\n  }\n}"
                }
            }
            split s3 {
                size = 30

                heading h3 {
                    level = 3
                    content = "Quick Links"
                }
                paragraph l1 { content = icon("github") + " " + link("GitHub Repository", "https://github.com/wiltaylor/wcl") }
                paragraph l2 { content = icon("book") + " " + link("API Documentation", "https://wcl.dev/docs") }
                paragraph l3 { content = icon("tag") + " " + link("Release Notes", "https://github.com/wiltaylor/wcl/releases") }
                paragraph l4 { content = icon("window") + " " + link("VS Code Extension", "https://marketplace.visualstudio.com") }
            }
        }
    }
}

// ── Language Basics page ──

wdoc_page basics {
    section = "my_docs.guide.basics"
    title = "Language Basics"

    wdoc_layout {
        vsplit v3 {
            split s4 {
                size = 100

                heading h1 {
                    level = 1
                    content = "Language Basics"
                }

                paragraph p1 {
                    content = "WCL is a " + bold("block-structured") + " configuration language. Everything is built from " + italic("blocks") + ", " + italic("attributes") + ", and " + italic("expressions") + "."
                }

                callout tip {
                    icon = "lightbulb"
                    header = "Getting Started"
                    color = "#0366d6"
                    paragraph tip_p1 { content = "New to WCL? Start with blocks and schemas, then explore expressions and imports." }
                }

                heading h2a {
                    level = 2
                    content = "Blocks and Attributes"
                }
                paragraph p2 { content = "Blocks are the fundamental building unit. Each block has a " + bold("kind") + " and an optional " + bold("ID") + ". Attributes are key-value pairs inside blocks:" }
                code c1 {
                    language = "wcl"
                    content = "// A block with kind 'server' and ID 'api'\nserver api {\n    host = \"0.0.0.0\"\n    port = 8080\n    workers = 4\n    tls = true\n\n    // Nested blocks\n    upstream backend {\n        host = \"10.0.1.1\"\n        port = 8081\n        weight = 100\n    }\n\n    logging {\n        level = \"info\"\n        format = \"json\"\n    }\n}"
                }

                heading h2b {
                    level = 2
                    content = "Variables and Expressions"
                }
                paragraph p3 { content = "Use " + bold("let") + " bindings for variables. WCL supports arithmetic, string interpolation, ternary expressions, and 45+ built-in functions:" }
                code c2 {
                    language = "wcl"
                    content = "let environment = \"production\"\nlet base_port = 8000\nlet is_prod = environment == \"production\"\nlet max_conn = is_prod ? 100 : 5\n\n// String interpolation\nlet greeting = \"Running in " + D + "{environment} mode\"\n\n// Built-in functions\nlet regions = [\"us-east\", \"eu-west\", \"ap-south\"]\nlet count = len(regions)\nlet upper_regions = map_fn(regions, fn(r) { upper(r) })\nlet hash = sha256(\"secret-key\")\nlet encoded = base64_encode(\"hello world\")"
                }

                heading h2c {
                    level = 2
                    content = "Schemas and Validation"
                }

                image img_schemas {
                    src = "images/schemas.png"
                    alt = "Schema validation diagram"
                }

                paragraph p4 { content = "Schemas define the expected structure and validate your configuration at " + bold("parse time") + ". Errors are caught before deployment:" }
                code c3 {
                    language = "wcl"
                    content = "schema \"server\" {\n    host: string\n    port: i64 @validate(min = 1, max = 65535)\n    workers: i64 @validate(min = 1, max = 32)\n    tls: bool @optional @default(false)\n    region: string @optional @validate(one_of = [\"us-east\", \"eu-west\", \"ap-south\"])\n}\n\n// Decorators provide metadata\n@doc(\"Primary API server\")\n@deprecated(\"Use the new gateway block instead\")\nserver api {\n    host = \"0.0.0.0\"\n    port = 8080\n    workers = 8\n}"
                }

                callout schema_note {
                    icon = "exclamation-triangle"
                    header = "Schema Validation"
                    color = "#e6a700"
                    paragraph sn_p1 { content = "Schema errors are caught at " + bold("parse time") + ", not runtime. This means invalid configs fail fast before deployment." }
                    code sn_c1 {
                        language = "bash"
                        content = "$ wcl validate config.wcl\nerror[E071]: type mismatch: expected i64, got string"
                    }
                }

                heading h2d {
                    level = 2
                    content = "Imports and Libraries"
                }
                paragraph p5 { content = "Split configuration across files and reuse shared definitions:" }
                code c4 {
                    language = "wcl"
                    content = "// Relative imports\nimport \"./schemas.wcl\"\nimport \"./defaults.wcl\"\n\n// Glob imports\nimport \"./services/*.wcl\"\n\n// Optional imports (no error if missing)\nimport? \"./local-overrides.wcl\"\n\n// Library imports (from search paths)\nimport <common-schemas.wcl>"
                }

                heading h2e {
                    level = 2
                    content = "Evaluated Output"
                }
                paragraph p6 { content = "WCL evaluates to structured data. Here is what the JSON output looks like:" }
                code c5 {
                    language = "json"
                    content = "{\n  \"server\": {\n    \"api\": {\n      \"host\": \"0.0.0.0\",\n      \"port\": 8080,\n      \"workers\": 8,\n      \"tls\": true\n    },\n    \"worker-us-east\": {\n      \"host\": \"us-east.internal\",\n      \"port\": 10000,\n      \"workers\": 4,\n      \"region\": \"us-east\"\n    }\n  }\n}"
                }

                heading h2f {
                    level = 2
                    content = "Tables"
                }
                paragraph p7 { content = "WCL supports inline data tables with typed columns. Here is how they look when rendered:" }

                wdoc_table tbl_servers {
                    caption = "Server Configuration"
                    table data {
                        name: string
                        host: string
                        port: i64
                        workers: i64
                        tls: bool
                        | "api"            | "0.0.0.0"           | 8080  | 8 | true  |
                        | "admin"          | "127.0.0.1"         | 9090  | 2 | false |
                        | "worker-us-east" | "us-east.internal"  | 10000 | 4 | true  |
                        | "worker-eu-west" | "eu-west.internal"  | 10000 | 4 | true  |
                    }
                }

                wdoc_table tbl_users {
                    caption = "Team Members"
                    table data {
                        name: string
                        role: string
                        admin: bool
                        | "alice" | "engineering" | true  |
                        | "bob"   | "marketing"  | false |
                        | "carol" | "engineering" | true  |
                        | "dave"  | "operations"  | false |
                    }
                }
            }
        }
    }
}

// ── Advanced Features page ──

wdoc_page advanced {
    section = "my_docs.guide.advanced"
    title = "Advanced Features"

    wdoc_layout {
        vsplit v4 {
            split s5 {
                size = 100
                heading h1 {
                    level = 1
                    content = "Advanced Features"
                }
                paragraph p1 { content = "WCL supports control flow, tables, macros, transforms, and more." }
            }
        }
        vsplit v5 {
            split s6 {
                size = 50

                heading h2a {
                    level = 2
                    content = "Control Flow"
                }
                paragraph p2 { content = "Generate blocks dynamically with " + bold("for") + " loops and " + bold("if/else") + " conditionals:" }
                code c1 {
                    language = "wcl"
                    content = "let regions = [\"us-east\", \"eu-west\"]\nlet is_prod = true\n\nfor region in regions {\n    server worker-" + D + "{region} {\n        host = \"" + D + "{region}.internal\"\n        port = 9000\n        workers = is_prod ? 8 : 2\n    }\n}\n\nif is_prod {\n    database primary {\n        host = \"db.internal\"\n        max_connections = 100\n        ssl = true\n    }\n} else {\n    database primary {\n        host = \"localhost\"\n        max_connections = 5\n    }\n}"
                }
            }
            split s7 {
                size = 50

                heading h2b {
                    level = 2
                    content = "Tables and CSV Import"
                }
                paragraph p3 { content = "Structured tabular data with typed columns, queryable with selectors:" }
                code c2 {
                    language = "wcl"
                    content = "// Inline table\ntable users {\n    name:  string\n    role:  string\n    admin: bool\n    | \"alice\" | \"eng\"   | true  |\n    | \"bob\"   | \"sales\" | false |\n    | \"carol\" | \"eng\"   | true  |\n}\n\n// Import from CSV\ntable inventory = import_table(\n    \"data/inventory.csv\",\n    headers = true\n)\n\n// Query table data\nlet admins = query(users | .admin == true)\nlet eng_count = len(query(users | .role == \"eng\"))"
                }

                paragraph p3b { content = "Rendered table output:" }
                wdoc_table tbl_users {
                    caption = "Users Table"
                    table data {
                        name: string
                        role: string
                        admin: bool
                        | "alice" | "eng"   | true  |
                        | "bob"   | "sales" | false |
                        | "carol" | "eng"   | true  |
                    }
                }
            }
        }
        vsplit v6 {
            split s8 {
                size = 50

                heading h2c {
                    level = 2
                    content = "Macros"
                }
                paragraph p4 { content = "Define reusable block templates with macros:" }
                code c3 {
                    language = "wcl"
                    content = "// Define a macro\nmacro standard_server(name, port) {\n    server " + D + "{name} {\n        host = \"0.0.0.0\"\n        port = port\n        workers = 4\n        tls = true\n        logging {\n            level = \"info\"\n            format = \"json\"\n        }\n    }\n}\n\n// Use the macro\nstandard_server(\"api\", 8080)\nstandard_server(\"admin\", 9090)"
                }
            }
            split s9 {
                size = 50

                heading h2d {
                    level = 2
                    content = "Data Transforms"
                }
                paragraph p5 { content = "Transform data between formats with the transform system:" }
                code c4 {
                    language = "wcl"
                    content = "transform csv_to_json {\n    input_format = \"csv\"\n    output_format = \"json\"\n\n    map row -> entry {\n        name = row.name\n        email = lower(row.email)\n        active = row.status == \"active\"\n        tags = split(row.tags, \",\")\n    }\n\n    filter entry {\n        check = entry.active == true\n    }\n}"
                }
            }
        }
        vsplit v6b {
            split s9b {
                size = 100

                heading h2e {
                    level = 2
                    content = "Diagrams"
                }
                paragraph p6 { content = "Create vector diagrams directly in WCL with shapes, connections, and layout:" }

                wdoc_diagram architecture {
                    width = 700
                    height = 280

                    shape_rect client {
                        x = 30
                        y = 100
                        width = 140
                        height = 70
                        rx = 8
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2

                        shape_text client_label {
                            content = "Client"
                            font_size = 16
                            fill = "var(--color-text)"
                        }
                    }

                    shape_rect api {
                        x = 260
                        y = 30
                        width = 160
                        height = 70
                        rx = 8
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2

                        shape_text api_label {
                            content = "API Server"
                            font_size = 16
                            fill = "var(--color-text)"
                        }
                    }

                    shape_rect db {
                        x = 260
                        y = 170
                        width = 160
                        height = 70
                        rx = 8
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2

                        shape_text db_label {
                            content = "Database"
                            font_size = 16
                            fill = "var(--color-text)"
                        }
                    }

                    shape_rect cache {
                        x = 520
                        y = 100
                        width = 140
                        height = 70
                        rx = 8
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2

                        shape_text cache_label {
                            content = "Cache"
                            font_size = 16
                            fill = "var(--color-text)"
                        }
                    }

                    shape_connection c1 {
                        from = "client"
                        to = "api"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        label = "HTTP"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    shape_connection c2 {
                        from = "api"
                        to = "db"
                        direction = "both"
                        from_anchor = "bottom"
                        to_anchor = "top"
                        label = "SQL"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    shape_connection c3 {
                        from = "api"
                        to = "cache"
                        direction = "both"
                        from_anchor = "right"
                        to_anchor = "left"
                        label = "Redis"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    shape_connection c4 {
                        from = "client"
                        to = "db"
                        direction = "to"
                        curve = "bezier"
                        from_anchor = "bottom"
                        to_anchor = "left"
                        label = "Direct Query"
                        stroke = "var(--color-text)"
                        stroke_width = 1
                        stroke_dasharray = "5,5"
                    }
                }
            }
        }
    }
}

// ── Diagram Examples page ──

wdoc_page diagram_examples {
    section = "my_docs.diagrams.diagram_examples"
    title = "Diagram Examples"

    wdoc_layout {
        vsplit v_diag1 {
            split s_diag1 {
                size = 100

                heading hd1 {
                    level = 1
                    content = "Diagram Examples"
                }
                paragraph pd1 { content = "WCL supports inline vector diagrams with shapes, connections, text labels, and theme-aware styling. Diagrams render as inline SVG." }
            }
        }

        // --- Example 1: Simple shapes ---
        vsplit v_diag2 {
            split s_diag2 {
                size = 100

                heading hd2 {
                    level = 2
                    content = "Basic Shapes"
                }
                paragraph pd2 { content = "Rectangles, circles, ellipses, and lines with theme-aware colors:" }

                wdoc_diagram basic_shapes {
                    width = 700
                    height = 200

                    shape_rect r1 {
                        x = 20
                        y = 30
                        width = 120
                        height = 80
                        rx = 8
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t1 { content = "Rectangle" }
                    }

                    shape_circle c1 {
                        x = 180
                        y = 30
                        r = 40
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t2 { content = "Circle" }
                    }

                    shape_ellipse e1 {
                        x = 300
                        y = 30
                        rx = 70
                        ry = 40
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t3 { content = "Ellipse" }
                    }

                    shape_line l1 {
                        x1 = 480
                        y1 = 40
                        x2 = 650
                        y2 = 40
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    shape_line l2 {
                        x1 = 480
                        y1 = 80
                        x2 = 650
                        y2 = 80
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        stroke_dasharray = "8,4"
                    }

                    shape_line l3 {
                        x1 = 480
                        y1 = 120
                        x2 = 650
                        y2 = 120
                        stroke = "var(--color-nav-border)"
                        stroke_width = 3
                    }

                    shape_text lines_label {
                        x = 480
                        y = 150
                        width = 170
                        height = 30
                        content = "Lines (solid, dashed, thick)"
                        font_size = 12
                        fill = "var(--color-text)"
                    }
                }
            }
        }

        // --- Example 2: Connections with arrows ---
        vsplit v_diag3 {
            split s_diag3 {
                size = 100

                heading hd3 {
                    level = 2
                    content = "Connections and Arrows"
                }
                paragraph pd3 { content = "Connect shapes with straight or bezier lines. Arrows indicate direction:" }

                wdoc_diagram conn_demo {
                    width = 700
                    height = 220

                    shape_rect a {
                        x = 30
                        y = 30
                        width = 120
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text ta { content = "Source" }
                    }

                    shape_rect b {
                        x = 280
                        y = 30
                        width = 120
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text tb { content = "Target" }
                    }

                    shape_rect c {
                        x = 530
                        y = 30
                        width = 120
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text tc { content = "Both" }
                    }

                    shape_rect d {
                        x = 30
                        y = 140
                        width = 120
                        height = 60
                        rx = 6
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text td { content = "Bezier" }
                    }

                    shape_rect e {
                        x = 530
                        y = 140
                        width = 120
                        height = 60
                        rx = 6
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text te { content = "Curve" }
                    }

                    shape_connection ab {
                        from = "a"
                        to = "b"
                        direction = "to"
                        label = "one-way"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    shape_connection bc {
                        from = "b"
                        to = "c"
                        direction = "both"
                        label = "bidirectional"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    shape_connection de {
                        from = "d"
                        to = "e"
                        direction = "to"
                        curve = "bezier"
                        label = "bezier curve"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                    }
                }
            }
        }

        // --- Example 3: Anchored layout ---
        vsplit v_diag4 {
            split s_diag4 {
                size = 100

                heading hd4 {
                    level = 2
                    content = "Anchored Positioning"
                }
                paragraph pd4 { content = "Shapes can be anchored to parent edges. They stretch to fill the space between anchors:" }

                wdoc_diagram anchored {
                    width = 700
                    height = 250

                    shape_rect outer {
                        left = 10
                        right = 10
                        top = 10
                        bottom = 10
                        rx = 4
                        fill = "none"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        stroke_dasharray = "4,4"

                        shape_rect header {
                            left = 0
                            right = 0
                            top = 0
                            height = 40
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            stroke_width = 1
                            shape_text ht { content = "Header (anchored top, full width)" }
                        }

                        shape_rect sidebar {
                            left = 0
                            top = 50
                            bottom = 50
                            width = 150
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text st { content = "Sidebar" }
                        }

                        shape_rect content_area {
                            left = 160
                            top = 50
                            right = 0
                            bottom = 50
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            stroke_width = 1
                            shape_text ct {
                                content = "Content (fills remaining space)"
                            }
                        }

                        shape_rect footer {
                            left = 0
                            right = 0
                            bottom = 0
                            height = 40
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            stroke_width = 1
                            shape_text ft { content = "Footer (anchored bottom, full width)" }
                        }
                    }
                }
            }
        }

        // --- Example 4: Stack layout ---
        vsplit v_diag5 {
            split s_diag5 {
                size = 100

                heading hd5 {
                    level = 2
                    content = "Stack Layout"
                }
                paragraph pd5 { content = "Use " + bold("align = \"stack\"") + " to automatically stack children vertically with spacing:" }

                wdoc_diagram stack_demo {
                    width = 400
                    height = 220

                    shape_rect container {
                        x = 20
                        y = 10
                        width = 360
                        height = 200
                        rx = 8
                        fill = "none"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        align = "stack"
                        gap = 10
                        padding = 15

                        shape_rect item1 {
                            height = 40
                            rx = 4
                            fill = "var(--color-link)"
                            shape_text t1 {
                                content = "Item 1"
                                fill = "#ffffff"
                            }
                        }

                        shape_rect item2 {
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-active)"
                            shape_text t2 { content = "Item 2" }
                        }

                        shape_rect item3 {
                            height = 40
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t3 { content = "Item 3" }
                        }
                    }
                }

                heading hd6 {
                    level = 2
                    content = "WCL Source"
                }
                paragraph pd6 { content = "Here is the WCL code for the stack layout diagram above:" }
                code cd1 {
                    language = "wcl"
                    content = "wdoc_diagram stack_demo {\n    width = 400\n    height = 220\n\n    shape_rect container {\n        x = 20\n        y = 10\n        width = 360\n        height = 200\n        align = \"stack\"\n        gap = 10\n        padding = 15\n\n        shape_rect item1 {\n            height = 40\n            fill = \"var(--color-link)\"\n            shape_text t1 { content = \"Item 1\" }\n        }\n        shape_rect item2 {\n            height = 40\n            fill = \"var(--color-nav-active)\"\n            shape_text t2 { content = \"Item 2\" }\n        }\n    }\n}"
                }
            }
        }

        // --- Example 5: Layered (Sugiyama) layout ---
        vsplit v_diag6 {
            split s_diag6 {
                size = 100

                heading hd7 {
                    level = 2
                    content = "Layered Layout (Flowchart)"
                }
                paragraph pd7 { content = "Use " + bold("align = \"layered\"") + " for directed graphs. Nodes are arranged in layers based on edge direction:" }

                wdoc_diagram layered_demo {
                    width = 600
                    height = 350
                    align = "layered"
                    gap = 40

                    shape_rect input {
                        width = 120
                        height = 50
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Input" }
                    }

                    shape_rect validate {
                        width = 120
                        height = 50
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Validate" }
                    }

                    shape_rect xform {
                        width = 120
                        height = 50
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Transform" }
                    }

                    shape_rect cache {
                        width = 120
                        height = 50
                        rx = 6
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Cache" }
                    }

                    shape_rect output {
                        width = 120
                        height = 50
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Output" }
                    }

                    shape_connection c1 {
                        from = "input"
                        to = "validate"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection c2 {
                        from = "validate"
                        to = "xform"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection c3 {
                        from = "xform"
                        to = "cache"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection c4 {
                        from = "xform"
                        to = "output"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                }
            }
        }

        // --- Example 6: Force-directed layout ---
        vsplit v_diag7 {
            split s_diag7 {
                size = 100

                heading hd8 {
                    level = 2
                    content = "Force-Directed Layout (Network)"
                }
                paragraph pd8 { content = "Use " + bold("align = \"force\"") + " for network diagrams. Connected nodes attract, all nodes repel:" }

                wdoc_diagram network {
                    width = 500
                    height = 350
                    align = "force"

                    shape_circle web {
                        r = 28
                        fill = "var(--color-link)"
                        shape_text t { content = "Web"
                            fill = "#fff" }
                    }
                    shape_circle api {
                        r = 28
                        fill = "var(--color-link)"
                        shape_text t { content = "API"
                            fill = "#fff" }
                    }
                    shape_circle auth {
                        r = 28
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Auth" }
                    }
                    shape_circle db {
                        r = 28
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "DB" }
                    }
                    shape_circle cache_node {
                        r = 28
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Cache" }
                    }
                    shape_circle queue {
                        r = 28
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 2
                        shape_text t { content = "Queue" }
                    }

                    shape_connection e1 {
                        from = "web"
                        to = "api"
                        direction = "to"
                        stroke = "var(--color-text)"
                    }
                    shape_connection e2 {
                        from = "api"
                        to = "auth"
                        direction = "both"
                        stroke = "var(--color-text)"
                    }
                    shape_connection e3 {
                        from = "api"
                        to = "db"
                        direction = "both"
                        stroke = "var(--color-text)"
                    }
                    shape_connection e4 {
                        from = "api"
                        to = "cache_node"
                        direction = "both"
                        stroke = "var(--color-text)"
                    }
                    shape_connection e5 {
                        from = "api"
                        to = "queue"
                        direction = "to"
                        stroke = "var(--color-text)"
                    }
                    shape_connection e6 {
                        from = "queue"
                        to = "db"
                        direction = "to"
                        stroke = "var(--color-text)"
                    }
                }
            }
        }

        // --- Example 7: Radial layout ---
        vsplit v_diag8 {
            split s_diag8 {
                size = 100

                heading hd9 {
                    level = 2
                    content = "Radial Layout (Hierarchy)"
                }
                paragraph pd9 { content = "Use " + bold("align = \"radial\"") + " with a " + bold("root") + " node for tree hierarchies:" }

                wdoc_diagram org {
                    width = 500
                    height = 400
                    align = "radial"
                    root = "ceo"

                    shape_circle ceo {
                        r = 30
                        fill = "var(--color-link)"
                        shape_text t { content = "CEO"
                            fill = "#fff" }
                    }
                    shape_circle cto {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "CTO" }
                    }
                    shape_circle cfo {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "CFO" }
                    }
                    shape_circle vpe {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "VP Eng" }
                    }
                    shape_circle eng1 {
                        r = 18
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Eng1" }
                    }
                    shape_circle eng2 {
                        r = 18
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Eng2" }
                    }
                    shape_circle fin1 {
                        r = 18
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Fin" }
                    }

                    shape_connection r1 {
                        from = "ceo"
                        to = "cto"
                        stroke = "var(--color-text)"
                    }
                    shape_connection r2 {
                        from = "ceo"
                        to = "cfo"
                        stroke = "var(--color-text)"
                    }
                    shape_connection r3 {
                        from = "ceo"
                        to = "vpe"
                        stroke = "var(--color-text)"
                    }
                    shape_connection r4 {
                        from = "vpe"
                        to = "eng1"
                        stroke = "var(--color-text)"
                    }
                    shape_connection r5 {
                        from = "vpe"
                        to = "eng2"
                        stroke = "var(--color-text)"
                    }
                    shape_connection r6 {
                        from = "cfo"
                        to = "fin1"
                        stroke = "var(--color-text)"
                    }
                }
            }
        }

        // --- Example 8: Grid layout ---
        vsplit v_diag9 {
            split s_diag9 {
                size = 100

                heading hd10 {
                    level = 2
                    content = "Grid Layout"
                }
                paragraph pd10 { content = "Use " + bold("align = \"grid\"") + " with optional " + bold("columns") + " for regular arrangements:" }

                wdoc_diagram dashboard {
                    width = 500
                    height = 300
                    align = "grid"
                    columns = 3
                    gap = 20

                    shape_rect s1 {
                        width = 100
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                        shape_text t { content = "Widget 1" }
                    }
                    shape_rect s2 {
                        width = 100
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                        shape_text t { content = "Widget 2" }
                    }
                    shape_rect s3 {
                        width = 100
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                        shape_text t { content = "Widget 3" }
                    }
                    shape_rect s4 {
                        width = 100
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                        shape_text t { content = "Widget 4" }
                    }
                    shape_rect s5 {
                        width = 100
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                        shape_text t { content = "Widget 5" }
                    }
                    shape_rect s6 {
                        width = 100
                        height = 60
                        rx = 6
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                        shape_text t { content = "Widget 6" }
                    }
                }
            }
        }
    }
}

// ── Large Scale Diagram Examples (generated with for loops) ──

let grid_items = ["auth", "users", "posts", "media", "search", "notify", "billing", "analytics", "config", "logging", "metrics", "cache", "queue", "storage", "gateway"]

wdoc_page large_diagrams {
    section = "my_docs.diagrams.large_diagrams"
    title = "Large Diagrams"

    wdoc_layout {
        // Large grid
        vsplit v_lg1 {
            split s_lg1 {
                size = 100

                heading hlg1 {
                    level = 2
                    content = "Large Grid (15 services)"
                }
                paragraph plg1 { content = "A grid layout with many items, generated with a WCL " + bold("for") + " loop:" }

                wdoc_diagram large_grid {
                    width = 700
                    height = 400
                    align = "grid"
                    columns = 5
                    gap = 15

                    for svc in grid_items {
                        shape_rect ${svc} {
                            width = 110
                            height = 55
                            rx = 6
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = svc }
                        }
                    }
                }
            }
        }

        // Large force-directed network
        vsplit v_lg2 {
            split s_lg2 {
                size = 100

                heading hlg2 {
                    level = 2
                    content = "Large Force Network (12 nodes)"
                }
                paragraph plg2 { content = "A complex force-directed network with many interconnections:" }

                wdoc_diagram large_force {
                    width = 700
                    height = 500
                    align = "force"

                    shape_circle f_web {
                        r = 25
                        fill = "var(--color-link)"
                        shape_text t { content = "Web"
                            fill = "#fff" }
                    }
                    shape_circle f_mobile {
                        r = 25
                        fill = "var(--color-link)"
                        shape_text t { content = "Mobile"
                            fill = "#fff" }
                    }
                    shape_circle f_gw {
                        r = 30
                        fill = "var(--color-link)"
                        shape_text t { content = "Gateway"
                            fill = "#fff" }
                    }
                    shape_circle f_auth {
                        r = 22
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Auth" }
                    }
                    shape_circle f_users {
                        r = 22
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Users" }
                    }
                    shape_circle f_posts {
                        r = 22
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Posts" }
                    }
                    shape_circle f_media {
                        r = 22
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Media" }
                    }
                    shape_circle f_search {
                        r = 22
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Search" }
                    }
                    shape_circle f_db {
                        r = 25
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "DB" }
                    }
                    shape_circle f_cache {
                        r = 22
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Cache" }
                    }
                    shape_circle f_queue {
                        r = 22
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Queue" }
                    }
                    shape_circle f_storage {
                        r = 22
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Storage" }
                    }

                    // Client → Gateway
                    shape_connection fe1 { from = "f_web"
                        to = "f_gw"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe2 { from = "f_mobile"
                        to = "f_gw"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    // Gateway → Services
                    shape_connection fe3 { from = "f_gw"
                        to = "f_auth"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe4 { from = "f_gw"
                        to = "f_users"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe5 { from = "f_gw"
                        to = "f_posts"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe6 { from = "f_gw"
                        to = "f_media"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    // Services → Data
                    shape_connection fe7 { from = "f_users"
                        to = "f_db"
                        direction = "both"
                        stroke = "var(--color-text)" }
                    shape_connection fe8 { from = "f_posts"
                        to = "f_db"
                        direction = "both"
                        stroke = "var(--color-text)" }
                    shape_connection fe9 { from = "f_posts"
                        to = "f_search"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe10 { from = "f_media"
                        to = "f_storage"
                        direction = "both"
                        stroke = "var(--color-text)" }
                    shape_connection fe11 { from = "f_auth"
                        to = "f_cache"
                        direction = "both"
                        stroke = "var(--color-text)" }
                    shape_connection fe12 { from = "f_posts"
                        to = "f_queue"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe13 { from = "f_queue"
                        to = "f_search"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection fe14 { from = "f_search"
                        to = "f_cache"
                        direction = "both"
                        stroke = "var(--color-text)" }
                }
            }
        }

        // Large layered pipeline
        vsplit v_lg3 {
            split s_lg3 {
                size = 100

                heading hlg3 {
                    level = 2
                    content = "Large Layered Pipeline (10 stages)"
                }
                paragraph plg3 { content = "A CI/CD pipeline with branching and merging stages:" }

                wdoc_diagram large_layered {
                    width = 700
                    height = 500
                    align = "layered"
                    gap = 30

                    shape_rect l_src {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Source" }
                    }
                    shape_rect l_lint {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Lint" }
                    }
                    shape_rect l_test {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Test" }
                    }
                    shape_rect l_build {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Build" }
                    }
                    shape_rect l_linux {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Linux" }
                    }
                    shape_rect l_macos {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "macOS" }
                    }
                    shape_rect l_windows {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Windows" }
                    }
                    shape_rect l_package {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Package" }
                    }
                    shape_rect l_staging {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Staging" }
                    }
                    shape_rect l_prod {
                        width = 100
                        height = 40
                        rx = 4
                        fill = "var(--color-link)"
                        shape_text t { content = "Production"
                            fill = "#fff" }
                    }

                    shape_connection lc1 { from = "l_src"
                        to = "l_lint"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection lc2 { from = "l_src"
                        to = "l_test"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection lc3 { from = "l_lint"
                        to = "l_build"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection lc4 { from = "l_test"
                        to = "l_build"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection lc5 { from = "l_build"
                        to = "l_linux"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection lc6 { from = "l_build"
                        to = "l_macos"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection lc7 { from = "l_build"
                        to = "l_windows"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection lc8 { from = "l_linux"
                        to = "l_package"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection lc9 { from = "l_macos"
                        to = "l_package"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection lc10 { from = "l_windows"
                        to = "l_package"
                        direction = "to"
                        stroke = "var(--color-text)" }
                    shape_connection lc11 { from = "l_package"
                        to = "l_staging"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection lc12 { from = "l_staging"
                        to = "l_prod"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                }
            }
        }

        // Radial with many nodes
        vsplit v_lg4 {
            split s_lg4 {
                size = 100

                heading hlg4 {
                    level = 2
                    content = "Large Radial Hierarchy (15 nodes)"
                }
                paragraph plg4 { content = "An org chart with three levels of hierarchy:" }

                wdoc_diagram large_radial {
                    width = 600
                    height = 500
                    align = "radial"
                    root = "r_ceo"

                    shape_circle r_ceo {
                        r = 30
                        fill = "var(--color-link)"
                        shape_text t { content = "CEO"
                            fill = "#fff" }
                    }
                    shape_circle r_cto {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "CTO" }
                    }
                    shape_circle r_cfo {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "CFO" }
                    }
                    shape_circle r_coo {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "COO" }
                    }
                    shape_circle r_cmo {
                        r = 24
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "CMO" }
                    }
                    shape_circle r_e1 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "FE"
                            font_size = 11 }
                    }
                    shape_circle r_e2 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "BE"
                            font_size = 11 }
                    }
                    shape_circle r_e3 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Infra"
                            font_size = 11 }
                    }
                    shape_circle r_f1 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Acct"
                            font_size = 11 }
                    }
                    shape_circle r_f2 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Tax"
                            font_size = 11 }
                    }
                    shape_circle r_o1 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "HR"
                            font_size = 11 }
                    }
                    shape_circle r_o2 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Ops"
                            font_size = 11 }
                    }
                    shape_circle r_m1 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Brand"
                            font_size = 11 }
                    }
                    shape_circle r_m2 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Growth"
                            font_size = 10 }
                    }
                    shape_circle r_m3 {
                        r = 16
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                        shape_text t { content = "Sales"
                            font_size = 11 }
                    }

                    // Level 1
                    shape_connection rc1 { from = "r_ceo"
                        to = "r_cto"
                        stroke = "var(--color-text)" }
                    shape_connection rc2 { from = "r_ceo"
                        to = "r_cfo"
                        stroke = "var(--color-text)" }
                    shape_connection rc3 { from = "r_ceo"
                        to = "r_coo"
                        stroke = "var(--color-text)" }
                    shape_connection rc4 { from = "r_ceo"
                        to = "r_cmo"
                        stroke = "var(--color-text)" }
                    // Level 2
                    shape_connection rc5 { from = "r_cto"
                        to = "r_e1"
                        stroke = "var(--color-text)" }
                    shape_connection rc6 { from = "r_cto"
                        to = "r_e2"
                        stroke = "var(--color-text)" }
                    shape_connection rc7 { from = "r_cto"
                        to = "r_e3"
                        stroke = "var(--color-text)" }
                    shape_connection rc8 { from = "r_cfo"
                        to = "r_f1"
                        stroke = "var(--color-text)" }
                    shape_connection rc9 { from = "r_cfo"
                        to = "r_f2"
                        stroke = "var(--color-text)" }
                    shape_connection rc10 { from = "r_coo"
                        to = "r_o1"
                        stroke = "var(--color-text)" }
                    shape_connection rc11 { from = "r_coo"
                        to = "r_o2"
                        stroke = "var(--color-text)" }
                    shape_connection rc12 { from = "r_cmo"
                        to = "r_m1"
                        stroke = "var(--color-text)" }
                    shape_connection rc13 { from = "r_cmo"
                        to = "r_m2"
                        stroke = "var(--color-text)" }
                    shape_connection rc14 { from = "r_cmo"
                        to = "r_m3"
                        stroke = "var(--color-text)" }
                }
            }
        }
    }
}

// ── Nested Diagrams page ──

wdoc_page nested_diagrams {
    section = "my_docs.diagrams.nested_diagrams"
    title = "Nested Diagrams"

    wdoc_layout {
        vsplit v_nd1 {
            split s_nd1 {
                size = 100

                heading hnd1 {
                    level = 1
                    content = "Nested Diagrams"
                }
                paragraph pnd1 {
                    content = "Shapes can contain other shapes, forming nested flowcharts. Connections can reference shapes at any nesting level using dot-separated paths (e.g. " + bold("\"parent.child\"") + ")."
                }
            }
        }

        // --- Example: System architecture with nested subsystems ---
        vsplit v_nd2 {
            split s_nd2 {
                size = 100

                heading hnd2 {
                    level = 2
                    content = "System Architecture with Nested Subsystems"
                }
                paragraph pnd2 { content = "Each subsystem box contains its own internal flowchart. Connections span across nesting levels:" }

                wdoc_diagram nested_arch {
                    width = 800
                    height = 550

                    // === Frontend Subsystem ===
                    shape_rect frontend {
                        x = 20
                        y = 20
                        width = 350
                        height = 220
                        rx = 12
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2

                        shape_text fe_title {
                            x = 10
                            y = 5
                            width = 330
                            height = 25
                            content = "Frontend"
                            font_size = 16
                        }

                        shape_rect fe_router {
                            x = 20
                            y = 40
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Router" }
                        }

                        shape_rect fe_auth_ui {
                            x = 20
                            y = 110
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Auth UI" }
                        }

                        shape_rect fe_dashboard {
                            x = 140
                            y = 110
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Dashboard" }
                        }

                        shape_rect fe_api_client {
                            x = 230
                            y = 40
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-link)"
                            stroke_width = 2
                            shape_text t { content = "API Client" }
                        }

                        // Internal frontend connections
                        shape_connection fec1 {
                            from = "fe_router"
                            to = "fe_auth_ui"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection fec2 {
                            from = "fe_router"
                            to = "fe_dashboard"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection fec3 {
                            from = "fe_dashboard"
                            to = "fe_api_client"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection fec4 {
                            from = "fe_auth_ui"
                            to = "fe_api_client"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                    }

                    // === Backend Subsystem ===
                    shape_rect backend {
                        x = 420
                        y = 20
                        width = 350
                        height = 220
                        rx = 12
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2

                        shape_text be_title {
                            x = 10
                            y = 5
                            width = 330
                            height = 25
                            content = "Backend"
                            font_size = 16
                        }

                        shape_rect be_gateway {
                            x = 15
                            y = 40
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-link)"
                            stroke_width = 2
                            shape_text t { content = "Gateway" }
                        }

                        shape_rect be_auth_svc {
                            x = 15
                            y = 110
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Auth Svc" }
                        }

                        shape_rect be_user_svc {
                            x = 130
                            y = 110
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "User Svc" }
                        }

                        shape_rect be_data_svc {
                            x = 240
                            y = 110
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Data Svc" }
                        }

                        shape_rect be_queue {
                            x = 240
                            y = 40
                            width = 100
                            height = 45
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Queue" }
                        }

                        // Internal backend connections
                        shape_connection bec1 {
                            from = "be_gateway"
                            to = "be_auth_svc"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection bec2 {
                            from = "be_gateway"
                            to = "be_user_svc"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection bec3 {
                            from = "be_gateway"
                            to = "be_data_svc"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection bec4 {
                            from = "be_data_svc"
                            to = "be_queue"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                    }

                    // === Data Layer ===
                    shape_rect data_layer {
                        x = 150
                        y = 300
                        width = 500
                        height = 220
                        rx = 12
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2

                        shape_text dl_title {
                            x = 10
                            y = 5
                            width = 480
                            height = 25
                            content = "Data Layer"
                            font_size = 16
                        }

                        shape_rect dl_postgres {
                            x = 20
                            y = 50
                            width = 110
                            height = 50
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "PostgreSQL" }
                        }

                        shape_rect dl_redis {
                            x = 150
                            y = 50
                            width = 110
                            height = 50
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Redis" }
                        }

                        shape_rect dl_s3 {
                            x = 280
                            y = 50
                            width = 110
                            height = 50
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "S3 Storage" }
                        }

                        shape_rect dl_elastic {
                            x = 80
                            y = 130
                            width = 110
                            height = 50
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Elastic" }
                        }

                        shape_rect dl_kafka {
                            x = 220
                            y = 130
                            width = 110
                            height = 50
                            rx = 4
                            fill = "var(--color-code-bg)"
                            stroke = "var(--color-code-border)"
                            stroke_width = 1
                            shape_text t { content = "Kafka" }
                        }

                        // Internal data connections
                        shape_connection dlc1 {
                            from = "dl_redis"
                            to = "dl_postgres"
                            direction = "both"
                            stroke = "var(--color-text)"
                            stroke_dasharray = "4,3"
                            label = "cache"
                        }
                        shape_connection dlc2 {
                            from = "dl_kafka"
                            to = "dl_elastic"
                            direction = "to"
                            stroke = "var(--color-text)"
                            label = "index"
                        }
                    }

                    // === Cross-hierarchy connections ===

                    // Frontend API Client → Backend Gateway
                    shape_connection xc1 {
                        from = "frontend.fe_api_client"
                        to = "backend.be_gateway"
                        direction = "to"
                        stroke = "var(--color-link)"
                        stroke_width = 3
                        label = "REST API"
                    }

                    // Backend Auth → Data Postgres
                    shape_connection xc2 {
                        from = "backend.be_auth_svc"
                        to = "data_layer.dl_postgres"
                        direction = "both"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                        label = "auth data"
                    }

                    // Backend User → Data Postgres
                    shape_connection xc3 {
                        from = "backend.be_user_svc"
                        to = "data_layer.dl_postgres"
                        direction = "both"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    // Backend User → Data Redis (cache)
                    shape_connection xc4 {
                        from = "backend.be_user_svc"
                        to = "data_layer.dl_redis"
                        direction = "both"
                        stroke = "var(--color-text)"
                        stroke_dasharray = "5,3"
                        label = "cache"
                    }

                    // Backend Data → Data S3
                    shape_connection xc5 {
                        from = "backend.be_data_svc"
                        to = "data_layer.dl_s3"
                        direction = "both"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                        label = "files"
                    }

                    // Backend Queue → Data Kafka
                    shape_connection xc6 {
                        from = "backend.be_queue"
                        to = "data_layer.dl_kafka"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                        label = "events"
                    }

                    // Backend Data → Data Elastic (search)
                    shape_connection xc7 {
                        from = "backend.be_data_svc"
                        to = "data_layer.dl_elastic"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_dasharray = "5,3"
                        label = "search"
                    }
                }
            }
        }

        // --- Example: Nested deployment flow ---
        vsplit v_nd3 {
            split s_nd3 {
                size = 100

                heading hnd3 {
                    level = 2
                    content = "Nested Deployment Pipeline"
                }
                paragraph pnd3 { content = "Each environment contains its own service topology. Connections show the promotion path between environments:" }

                wdoc_diagram deploy_flow {
                    width = 800
                    height = 400

                    // === Dev Environment ===
                    shape_rect env_dev {
                        x = 20
                        y = 30
                        width = 230
                        height = 340
                        rx = 10
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2

                        shape_text dev_label {
                            x = 10
                            y = 5
                            width = 210
                            height = 25
                            content = "Development"
                            font_size = 15
                        }

                        shape_rect dev_api {
                            x = 20
                            y = 40
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "API" }
                        }
                        shape_rect dev_web {
                            x = 120
                            y = 40
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "Web" }
                        }
                        shape_rect dev_worker {
                            x = 20
                            y = 100
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "Worker" }
                        }
                        shape_rect dev_db {
                            x = 120
                            y = 100
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "DB" }
                        }

                        shape_connection dc1 {
                            from = "dev_web"
                            to = "dev_api"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection dc2 {
                            from = "dev_api"
                            to = "dev_db"
                            direction = "both"
                            stroke = "var(--color-text)"
                        }
                        shape_connection dc3 {
                            from = "dev_api"
                            to = "dev_worker"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                    }

                    // === Staging Environment ===
                    shape_rect env_staging {
                        x = 290
                        y = 30
                        width = 230
                        height = 340
                        rx = 10
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2

                        shape_text stg_label {
                            x = 10
                            y = 5
                            width = 210
                            height = 25
                            content = "Staging"
                            font_size = 15
                        }

                        shape_rect stg_api {
                            x = 20
                            y = 40
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "API" }
                        }
                        shape_rect stg_web {
                            x = 120
                            y = 40
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "Web" }
                        }
                        shape_rect stg_worker {
                            x = 20
                            y = 100
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "Worker" }
                        }
                        shape_rect stg_db {
                            x = 120
                            y = 100
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "DB" }
                        }

                        shape_connection sc1 {
                            from = "stg_web"
                            to = "stg_api"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection sc2 {
                            from = "stg_api"
                            to = "stg_db"
                            direction = "both"
                            stroke = "var(--color-text)"
                        }
                        shape_connection sc3 {
                            from = "stg_api"
                            to = "stg_worker"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                    }

                    // === Production Environment ===
                    shape_rect env_prod {
                        x = 560
                        y = 30
                        width = 230
                        height = 340
                        rx = 10
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 3

                        shape_text prod_label {
                            x = 10
                            y = 5
                            width = 210
                            height = 25
                            content = "Production"
                            font_size = 15
                        }

                        shape_rect prod_api {
                            x = 20
                            y = 40
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "API x3" }
                        }
                        shape_rect prod_web {
                            x = 120
                            y = 40
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "Web x3" }
                        }
                        shape_rect prod_worker {
                            x = 20
                            y = 100
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "Worker x5" }
                        }
                        shape_rect prod_db {
                            x = 120
                            y = 100
                            width = 85
                            height = 40
                            rx = 4
                            fill = "var(--color-nav-bg)"
                            stroke = "var(--color-nav-border)"
                            shape_text t { content = "DB HA" }
                        }

                        shape_connection pc1 {
                            from = "prod_web"
                            to = "prod_api"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                        shape_connection pc2 {
                            from = "prod_api"
                            to = "prod_db"
                            direction = "both"
                            stroke = "var(--color-text)"
                        }
                        shape_connection pc3 {
                            from = "prod_api"
                            to = "prod_worker"
                            direction = "to"
                            stroke = "var(--color-text)"
                        }
                    }

                    // === Cross-environment promotion connections ===
                    shape_connection promote_dev_stg {
                        from = "env_dev"
                        to = "env_staging"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 3
                        label = "promote"
                    }

                    shape_connection promote_stg_prod {
                        from = "env_staging"
                        to = "env_prod"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 3
                        label = "deploy"
                    }

                    // Cross-env data connections
                    shape_connection data_sync_1 {
                        from = "env_dev.dev_db"
                        to = "env_staging.stg_db"
                        direction = "to"
                        curve = "bezier"
                        from_anchor = "bottom"
                        to_anchor = "bottom"
                        stroke = "var(--color-text)"
                        stroke_dasharray = "5,3"
                        label = "schema sync"
                    }

                    shape_connection data_sync_2 {
                        from = "env_staging.stg_db"
                        to = "env_prod.prod_db"
                        direction = "to"
                        curve = "bezier"
                        from_anchor = "bottom"
                        to_anchor = "bottom"
                        stroke = "var(--color-text)"
                        stroke_dasharray = "5,3"
                        label = "migrate"
                    }
                }
            }
        }
    }
}

// ── Swim Lane Diagrams page ──

wdoc_page swimlane_diagrams {
    section = "my_docs.diagrams.swimlane_diagrams"
    title = "Swim Lane Diagrams"

    wdoc_layout {
        vsplit v_sw1 {
            split s_sw1 {
                size = 100

                heading hsw1 {
                    level = 1
                    content = "Swim Lane Diagrams"
                }
                paragraph psw1 {
                    content = "Swim lane diagrams use anchored rectangles as lanes with shapes inside each lane. Connections cross lane boundaries to show handoffs between actors."
                }
            }
        }

        // --- Example 1: Order Processing ---
        vsplit v_sw2 {
            split s_sw2 {
                size = 100

                heading hsw2 {
                    level = 2
                    content = "Order Processing Flow"
                }
                paragraph psw2 { content = "Three swim lanes showing the handoffs between Customer, System, and Warehouse:" }

                wdoc_diagram order_flow {
                    width = 800
                    height = 500

                    // Lane backgrounds (anchored full-height strips)
                    shape_rect lane_customer {
                        left = 0
                        top = 40
                        bottom = 0
                        width = 250
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                    }
                    shape_rect lane_system {
                        left = 260
                        top = 40
                        bottom = 0
                        width = 260
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                    }
                    shape_rect lane_warehouse {
                        left = 530
                        top = 40
                        bottom = 0
                        width = 270
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                    }

                    // Lane headers
                    shape_rect hdr_customer {
                        x = 0
                        y = 0
                        width = 250
                        height = 40
                        fill = "var(--color-link)"
                        shape_text t { content = "Customer"
                            fill = "#fff"
                            font_size = 15 }
                    }
                    shape_rect hdr_system {
                        x = 260
                        y = 0
                        width = 260
                        height = 40
                        fill = "var(--color-link)"
                        shape_text t { content = "System"
                            fill = "#fff"
                            font_size = 15 }
                    }
                    shape_rect hdr_warehouse {
                        x = 530
                        y = 0
                        width = 270
                        height = 40
                        fill = "var(--color-link)"
                        shape_text t { content = "Warehouse"
                            fill = "#fff"
                            font_size = 15 }
                    }

                    // Customer lane steps
                    shape_rect c_browse {
                        x = 50
                        y = 70
                        width = 150
                        height = 45
                        rx = 20
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Browse Items" }
                    }
                    shape_rect c_order {
                        x = 50
                        y = 150
                        width = 150
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Place Order" }
                    }
                    shape_rect c_pay {
                        x = 50
                        y = 240
                        width = 150
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Pay" }
                    }
                    shape_rect c_receive {
                        x = 50
                        y = 420
                        width = 150
                        height = 45
                        rx = 20
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Receive Package" }
                    }

                    // System lane steps
                    shape_rect s_validate {
                        x = 310
                        y = 150
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Validate Order" }
                    }
                    shape_rect s_payment {
                        x = 310
                        y = 240
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Process Payment" }
                    }
                    shape_rect s_notify {
                        x = 310
                        y = 330
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Send Notification" }
                    }
                    shape_rect s_tracking {
                        x = 310
                        y = 420
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Update Tracking" }
                    }

                    // Warehouse lane steps
                    shape_rect w_check {
                        x = 580
                        y = 240
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 2
                        shape_text t { content = "Check Stock" }
                    }
                    shape_rect w_pick {
                        x = 580
                        y = 330
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 2
                        shape_text t { content = "Pick & Pack" }
                    }
                    shape_rect w_ship {
                        x = 580
                        y = 420
                        width = 160
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 2
                        shape_text t { content = "Ship" }
                    }

                    // In-lane connections
                    shape_connection oc1 {
                        from = "c_browse"
                        to = "c_order"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection oc7 {
                        from = "w_check"
                        to = "w_pick"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection oc8 {
                        from = "w_pick"
                        to = "w_ship"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    // Cross-lane connections (handoffs)
                    shape_connection oc2 {
                        from = "c_order"
                        to = "s_validate"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "submit"
                    }
                    shape_connection oc3 {
                        from = "c_pay"
                        to = "s_payment"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                    }
                    shape_connection oc4 {
                        from = "s_validate"
                        to = "s_payment"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection oc5 {
                        from = "s_payment"
                        to = "w_check"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "fulfill"
                    }
                    shape_connection oc9 {
                        from = "w_ship"
                        to = "s_tracking"
                        direction = "to"
                        from_anchor = "left"
                        to_anchor = "right"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "shipped"
                    }
                    shape_connection oc10 {
                        from = "s_notify"
                        to = "c_receive"
                        direction = "to"
                        from_anchor = "left"
                        to_anchor = "right"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                    }
                    shape_connection oc11 {
                        from = "s_tracking"
                        to = "s_notify"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                }
            }
        }

        // --- Example 2: Horizontal swim lanes (user registration) ---
        vsplit v_sw3 {
            split s_sw3 {
                size = 100

                heading hsw3 {
                    level = 2
                    content = "User Registration (Horizontal Lanes)"
                }
                paragraph psw3 { content = "Horizontal swim lanes with the flow going left-to-right:" }

                wdoc_diagram reg_flow {
                    width = 800
                    height = 420

                    // Horizontal lane backgrounds
                    shape_rect lane_user {
                        left = 80
                        top = 0
                        right = 0
                        height = 130
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                    }
                    shape_rect lane_api {
                        left = 80
                        top = 140
                        right = 0
                        height = 130
                        fill = "var(--color-nav-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 1
                    }
                    shape_rect lane_email {
                        left = 80
                        top = 280
                        right = 0
                        height = 130
                        fill = "var(--color-code-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 1
                    }

                    // Lane labels (rotated via vertical text positioning)
                    shape_rect lbl_user {
                        x = 0
                        y = 0
                        width = 75
                        height = 130
                        fill = "var(--color-link)"
                        shape_text t { content = "User"
                            fill = "#fff"
                            font_size = 14 }
                    }
                    shape_rect lbl_api {
                        x = 0
                        y = 140
                        width = 75
                        height = 130
                        fill = "var(--color-link)"
                        shape_text t { content = "API"
                            fill = "#fff"
                            font_size = 14 }
                    }
                    shape_rect lbl_email {
                        x = 0
                        y = 280
                        width = 75
                        height = 130
                        fill = "var(--color-link)"
                        shape_text t { content = "Email"
                            fill = "#fff"
                            font_size = 14 }
                    }

                    // User lane steps
                    shape_rect u_signup {
                        x = 110
                        y = 35
                        width = 120
                        height = 45
                        rx = 20
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Sign Up" }
                    }
                    shape_rect u_fill {
                        x = 290
                        y = 35
                        width = 120
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Fill Form" }
                    }
                    shape_rect u_verify {
                        x = 570
                        y = 35
                        width = 120
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        shape_text t { content = "Click Link" }
                    }

                    // API lane steps
                    shape_rect a_validate {
                        x = 290
                        y = 180
                        width = 120
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Validate" }
                    }
                    shape_rect a_create {
                        x = 460
                        y = 180
                        width = 120
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Create User" }
                    }
                    shape_rect a_activate {
                        x = 630
                        y = 180
                        width = 120
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-nav-border)"
                        stroke_width = 2
                        shape_text t { content = "Activate" }
                    }

                    // Email lane steps
                    shape_rect e_send {
                        x = 460
                        y = 320
                        width = 130
                        height = 45
                        rx = 6
                        fill = "var(--color-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 2
                        shape_text t { content = "Send Verify" }
                    }
                    shape_rect e_welcome {
                        x = 630
                        y = 320
                        width = 130
                        height = 45
                        rx = 20
                        fill = "var(--color-bg)"
                        stroke = "var(--color-code-border)"
                        stroke_width = 2
                        shape_text t { content = "Welcome Mail" }
                    }

                    // In-lane flow
                    shape_connection rc1 {
                        from = "u_signup"
                        to = "u_fill"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }
                    shape_connection rc5 {
                        from = "a_validate"
                        to = "a_create"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                    }

                    // Cross-lane handoffs
                    shape_connection rc2 {
                        from = "u_fill"
                        to = "a_validate"
                        direction = "to"
                        from_anchor = "bottom"
                        to_anchor = "top"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "POST"
                    }
                    shape_connection rc3 {
                        from = "a_create"
                        to = "e_send"
                        direction = "to"
                        from_anchor = "bottom"
                        to_anchor = "top"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "trigger"
                    }
                    shape_connection rc4 {
                        from = "e_send"
                        to = "u_verify"
                        direction = "to"
                        from_anchor = "top"
                        to_anchor = "bottom"
                        curve = "bezier"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "email link"
                    }
                    shape_connection rc6 {
                        from = "u_verify"
                        to = "a_activate"
                        direction = "to"
                        from_anchor = "bottom"
                        to_anchor = "top"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "GET"
                    }
                    shape_connection rc7 {
                        from = "a_activate"
                        to = "e_welcome"
                        direction = "to"
                        from_anchor = "bottom"
                        to_anchor = "top"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                    }
                }
            }
        }
    }
}

// ── UI Wireframes page ──

wdoc_page wireframes {
    section = "my_docs.diagrams.wireframes"
    title = "UI Wireframes"

    wdoc_layout {
        vsplit v_wf1 {
            split s_wf1 {
                size = 100

                heading hwf1 {
                    level = 1
                    content = "UI Wireframes"
                }
                paragraph pwf1 { content = "Reusable UI widget shapes built from diagram primitives. Each widget is a schema with a template that returns shape primitives — no SVG hardcoding." }
            }
        }

        // --- Widget showcase: phone, browser, buttons, inputs ---
        vsplit v_wf2 {
            split s_wf2 {
                size = 100

                heading hwf2 {
                    level = 2
                    content = "Phone and Browser Frames"
                }
                paragraph pwf2 { content = "Use " + bold("widget_phone") + " and " + bold("widget_browser") + " for device mockups. They accept " + bold("title") + ", " + bold("url") + ", and color attributes:" }

                wdoc_diagram device_frames {
                    width = 750
                    height = 340

                    widget_phone phone1 {
                        x = 20
                        y = 10
                        width = 220
                        height = 320
                        title = "My App"
                    }

                    widget_phone phone2 {
                        x = 260
                        y = 10
                        width = 220
                        height = 320
                        title = "Settings"
                        header_fill = "var(--color-nav-bg)"
                    }

                    widget_browser browser1 {
                        x = 500
                        y = 10
                        width = 240
                        height = 180
                        title = "Dashboard"
                        url = "https://app.example.com"
                    }

                    widget_browser browser2 {
                        x = 500
                        y = 200
                        width = 240
                        height = 130
                        title = "Docs"
                        url = "https://docs.example.com"
                    }
                }
            }
        }

        // --- Buttons and inputs ---
        vsplit v_wf3 {
            split s_wf3 {
                size = 100

                heading hwf3 {
                    level = 2
                    content = "Buttons, Inputs, and Controls"
                }

                wdoc_diagram controls {
                    width = 700
                    height = 220

                    // Button variants
                    widget_button btn1 {
                        x = 20
                        y = 20
                        width = 120
                        height = 38
                        label = "Primary"
                        variant = "primary"
                    }
                    widget_button btn2 {
                        x = 150
                        y = 20
                        width = 120
                        height = 38
                        label = "Secondary"
                        variant = "secondary"
                    }
                    widget_button btn3 {
                        x = 280
                        y = 20
                        width = 120
                        height = 38
                        label = "Outline"
                        variant = "outline"
                    }

                    // Input fields
                    widget_input inp1 {
                        x = 20
                        y = 80
                        width = 200
                        height = 55
                        label = "Email"
                        placeholder = "you@example.com"
                    }
                    widget_input inp2 {
                        x = 240
                        y = 80
                        width = 200
                        height = 55
                        label = "Password"
                        placeholder = "********"
                    }

                    // Toggles
                    widget_toggle tog1 {
                        x = 20
                        y = 160
                        width = 44
                        height = 24
                        on = "true"
                    }
                    widget_toggle tog2 {
                        x = 80
                        y = 160
                        width = 44
                        height = 24
                        on = "false"
                    }

                    // Badges
                    widget_badge badge1 {
                        x = 150
                        y = 160
                        width = 70
                        height = 24
                        label = "Active"
                        color = "var(--color-link)"
                    }
                    widget_badge badge2 {
                        x = 230
                        y = 160
                        width = 80
                        height = 24
                        label = "Warning"
                        color = "#e6a700"
                    }
                    widget_badge badge3 {
                        x = 320
                        y = 160
                        width = 60
                        height = 24
                        label = "Error"
                        color = "#d32f2f"
                    }

                    // Avatars
                    widget_avatar av1 {
                        x = 460
                        y = 20
                        width = 50
                        height = 50
                        initials = "AT"
                        color = "var(--color-link)"
                    }
                    widget_avatar av2 {
                        x = 520
                        y = 20
                        width = 50
                        height = 50
                        initials = "BK"
                        color = "#8b5cf6"
                    }
                    widget_avatar av3 {
                        x = 580
                        y = 20
                        width = 50
                        height = 50
                        initials = "CD"
                        color = "#059669"
                    }
                    widget_avatar av4 {
                        x = 640
                        y = 20
                        width = 50
                        height = 50
                        initials = "EF"
                        color = "#dc2626"
                    }

                    // Navbar
                    widget_navbar nav1 {
                        x = 460
                        y = 90
                        width = 230
                        height = 40
                        items = "Home,Projects,Settings"
                        active_index = 0
                    }
                    widget_navbar nav2 {
                        x = 460
                        y = 140
                        width = 230
                        height = 40
                        items = "Feed,Search,Profile,More"
                        active_index = 2
                    }
                }
            }
        }

        // --- Cards with content ---
        vsplit v_wf4 {
            split s_wf4 {
                size = 100

                heading hwf4 {
                    level = 2
                    content = "Cards and Composition"
                }
                paragraph pwf4 { content = "Widgets can contain additional shapes. The widget template provides the structure, user shapes are added on top:" }

                wdoc_diagram card_demo {
                    width = 700
                    height = 250

                    widget_card card1 {
                        x = 20
                        y = 10
                        width = 200
                        height = 220
                        title = "User Profile"

                        // Custom content inside the card
                        widget_avatar av {
                            x = 70
                            y = 45
                            width = 60
                            height = 60
                            initials = "JD"
                            color = "var(--color-link)"
                        }
                        shape_text name {
                            x = 20
                            y = 120
                            width = 160
                            height = 20
                            content = "Jane Doe"
                            font_size = 14
                        }
                        shape_text role {
                            x = 20
                            y = 140
                            width = 160
                            height = 18
                            content = "Engineering Lead"
                            font_size = 11
                            opacity = 0.6
                        }
                        widget_badge status {
                            x = 55
                            y = 165
                            width = 90
                            height = 22
                            label = "Available"
                            color = "#059669"
                        }
                    }

                    widget_card card2 {
                        x = 240
                        y = 10
                        width = 200
                        height = 220
                        title = "Statistics"

                        shape_text stat1_label {
                            x = 15
                            y = 45
                            width = 170
                            height = 16
                            content = "Active Users"
                            font_size = 11
                            anchor = "start"
                            opacity = 0.6
                        }
                        shape_text stat1_val {
                            x = 15
                            y = 65
                            width = 170
                            height = 25
                            content = "12,847"
                            font_size = 24
                            anchor = "start"
                        }
                        shape_text stat2_label {
                            x = 15
                            y = 105
                            width = 170
                            height = 16
                            content = "Revenue"
                            font_size = 11
                            anchor = "start"
                            opacity = 0.6
                        }
                        shape_text stat2_val {
                            x = 15
                            y = 125
                            width = 170
                            height = 25
                            content = "$284K"
                            font_size = 24
                            anchor = "start"
                        }
                        widget_badge trend {
                            x = 55
                            y = 170
                            width = 90
                            height = 22
                            label = "+12.5%"
                            color = "#059669"
                        }
                    }

                    widget_card card3 {
                        x = 460
                        y = 10
                        width = 220
                        height = 220
                        title = "Quick Actions"

                        widget_button act1 {
                            x = 15
                            y = 45
                            width = 190
                            height = 34
                            label = "New Project"
                            variant = "primary"
                        }
                        widget_button act2 {
                            x = 15
                            y = 90
                            width = 190
                            height = 34
                            label = "Invite Member"
                            variant = "secondary"
                        }
                        widget_button act3 {
                            x = 15
                            y = 135
                            width = 190
                            height = 34
                            label = "View Reports"
                            variant = "outline"
                        }
                    }
                }
            }
        }

        // --- Login form using widgets ---
        vsplit v_wf5 {
            split s_wf5 {
                size = 100

                heading hwf5 {
                    level = 2
                    content = "Login Form (composed from widgets)"
                }

                wdoc_diagram login {
                    width = 400
                    height = 380

                    widget_card form {
                        x = 20
                        y = 10
                        width = 360
                        height = 360

                        widget_avatar logo {
                            x = 145
                            y = 15
                            width = 50
                            height = 50
                            initials = "W"
                            color = "var(--color-link)"
                        }

                        shape_text title {
                            x = 30
                            y = 75
                            width = 300
                            height = 25
                            content = "Welcome back"
                            font_size = 20
                        }

                        widget_input email {
                            x = 30
                            y = 115
                            width = 300
                            height = 55
                            label = "Email"
                            placeholder = "you@example.com"
                        }

                        widget_input password {
                            x = 30
                            y = 185
                            width = 300
                            height = 55
                            label = "Password"
                            placeholder = "********"
                        }

                        widget_button signin {
                            x = 30
                            y = 260
                            width = 300
                            height = 40
                            label = "Sign In"
                            variant = "primary"
                        }

                        widget_button github {
                            x = 30
                            y = 315
                            width = 142
                            height = 35
                            label = "GitHub"
                            variant = "outline"
                        }
                        widget_button google {
                            x = 188
                            y = 315
                            width = 142
                            height = 35
                            label = "Google"
                            variant = "outline"
                        }
                    }
                }
            }
        }

        // --- Clickable interactive diagram ---
        vsplit v_wf6 {
            split s_wf6 {
                size = 100

                heading hwf6 {
                    level = 2
                    content = "Interactive Clickable Diagram"
                }
                paragraph pwf6 { content = "Shapes with an " + bold("href") + " attribute become clickable links. Click the screens below to navigate:" }

                wdoc_diagram clickable_screens {
                    width = 750
                    height = 380

                    widget_phone screen_overview {
                        x = 20
                        y = 30
                        width = 200
                        height = 300
                        title = "Overview"
                        href = "overview.html"
                    }

                    widget_phone screen_install {
                        x = 240
                        y = 30
                        width = 200
                        height = 300
                        title = "Install"
                        href = "install.html"
                    }

                    widget_browser screen_basics {
                        x = 470
                        y = 30
                        width = 260
                        height = 160
                        title = "Basics"
                        url = "Language Basics"
                        href = "basics.html"
                    }

                    widget_browser screen_advanced {
                        x = 470
                        y = 210
                        width = 260
                        height = 120
                        title = "Advanced"
                        url = "Advanced Features"
                        href = "advanced.html"
                    }

                    shape_connection nav1 {
                        from = "screen_overview"
                        to = "screen_install"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "next"
                    }

                    shape_connection nav2 {
                        from = "screen_install"
                        to = "screen_basics"
                        direction = "to"
                        from_anchor = "right"
                        to_anchor = "left"
                        stroke = "var(--color-link)"
                        stroke_width = 2
                        label = "next"
                    }
                }

                paragraph pwf6b { content = "Internal page links also work in text: " + link("Go to Overview", "overview.html") + " | " + link("Installation", "install.html#installation") + " | " + link("Schemas section", "basics.html#schemas-and-validation") }
            }
        }
    }
}


// ── Flowchart Shapes page ──

wdoc_page flowchart_examples {
    section = "my_docs.diagrams.flowchart_examples"
    title = "Flowchart Shapes"

    wdoc_layout {
        vsplit v_fc1 {
            split s_fc1 {
                size = 100

                heading hfc1 {
                    level = 1
                    content = "Flowchart Shapes"
                }
                paragraph pfc1 { content = "All five flowchart shape types with the " + bold("layered") + " layout engine:" }

                wdoc_diagram flowchart_demo {
                    width = 700
                    height = 500
                    align = "layered"
                    gap = 40

                    widget_flow_terminal start {
                        width = 130
                        height = 40
                        label = "Start"
                    }

                    widget_flow_io input_data {
                        width = 150
                        height = 50
                        label = "Read Input"
                    }

                    widget_flow_process validate {
                        width = 150
                        height = 50
                        label = "Validate Data"
                    }

                    widget_flow_decision is_valid {
                        width = 110
                        height = 80
                        label = "Valid?"
                    }

                    widget_flow_subprocess process_data {
                        width = 160
                        height = 50
                        label = "Process Data"
                    }

                    widget_flow_process log_error {
                        width = 140
                        height = 50
                        label = "Log Error"
                        color = "#d32f2f"
                    }

                    widget_flow_io write_output {
                        width = 150
                        height = 50
                        label = "Write Output"
                    }

                    widget_flow_terminal done {
                        width = 130
                        height = 40
                        label = "End"
                        color = "#28a745"
                    }

                    shape_connection fc1 { from = "start"
                        to = "input_data"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection fc2 { from = "input_data"
                        to = "validate"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection fc3 { from = "validate"
                        to = "is_valid"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection fc4 { from = "is_valid"
                        to = "process_data"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2
                        label = "Yes" }
                    shape_connection fc5 { from = "is_valid"
                        to = "log_error"
                        direction = "to"
                        stroke = "#d32f2f"
                        stroke_width = 2
                        label = "No" }
                    shape_connection fc6 { from = "process_data"
                        to = "write_output"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection fc7 { from = "write_output"
                        to = "done"
                        direction = "to"
                        stroke = "var(--color-text)"
                        stroke_width = 2 }
                    shape_connection fc8 { from = "log_error"
                        to = "done"
                        direction = "to"
                        stroke = "#d32f2f"
                        stroke_width = 1
                        stroke_dasharray = "5,3" }
                }
            }
        }
    }
}

