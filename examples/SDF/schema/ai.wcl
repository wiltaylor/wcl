// ═══════════════════════════════════════════════════════════════════════════════
// AI Skill, Agent, Plugin, Hook, etc.
// ═══════════════════════════════════════════════════════════════════════════════

@doc("An AI skill — a composable, reusable capability powered by AI.")
@children([
    "trigger", "tool", "parameter", "output",
    "data_store", "agent", "procedure", "actions",
    "behaviour", "constraint"
])
@parent(["_root", "ai_plugin"])
schema "ai_skill" {
    description:    string @optional
    user_invocable: bool   @optional @default(false)
    repository_ref: string @optional @doc("Repository block this skill belongs to.")
}

@doc("An AI agent — a delegatable sub-agent.")
@children([
    "trigger", "tool", "parameter", "output",
    "data_store", "agent", "actions",
    "behaviour", "constraint"
])
@parent(["_root", "ai_plugin"])
schema "ai_agent" {
    description:    string @optional
    system_prompt:  string @optional
    repository_ref: string @optional
}

@doc("A Claude Code plugin directory containing components that extend Claude Code.")
@children([
    "author", "ai_skill", "ai_agent", "ai_hook",
    "ai_output_style", "ai_mcp_server", "ai_shared_folder",
    "behaviour", "constraint"
])
@parent(["_root"])
schema "ai_plugin" {
    description:    string @optional
    version:        string @optional @doc("Semantic version (MAJOR.MINOR.PATCH).")
    repository_ref: string @optional
    homepage:       string @optional @doc("Documentation URL.")
    repository_url: string @optional @doc("Source code URL.")
    license:        string @optional @doc("SPDX license identifier.")
    description:    string @optional
}

@doc("A Claude Code hook — an event-driven lifecycle handler.")
@children(["handler", "behaviour", "constraint"])
@parent(["_root", "ai_plugin"])
schema "ai_hook" {
    event:          string @doc("Lifecycle event (PreToolUse, PostToolUse, SessionStart, etc.).")
    matcher:        string @optional @doc("Pattern to match against the event payload.")
    description:    string @optional
    repository_ref: string @optional
}

@doc("A Claude Code output style — system prompt modification.")
@children(["behaviour", "constraint"])
@parent(["_root", "ai_plugin"])
schema "ai_output_style" {
    content:                 string @doc("The system prompt modification text.")
    keep_coding_instructions: bool  @optional @default(true)
    description:             string @optional
    repository_ref:          string @optional
}

@doc("A Model Context Protocol (MCP) server.")
@children(["oauth", "behaviour", "constraint"])
@parent(["_root", "ai_plugin"])
schema "ai_mcp_server" {
    transport:      string @optional @doc("Transport type (stdio, sse, http).")
    command:        string @optional @doc("Command to start the server.")
    cwd:            string @optional @doc("Working directory.")
    url:            string @optional @doc("URL for HTTP-based servers.")
    description:    string @optional
    repository_ref: string @optional
}

@doc("OAuth configuration for an HTTP-based MCP server.")
@children([])
@parent(["ai_mcp_server"])
schema "oauth" {
    client_id:     string @doc("OAuth client ID.")
    callback_port: int    @optional @doc("Local callback port.")
}

@doc("A shared resource folder accessible to AI skills and agents.")
@children(["ai_shared_file", "behaviour", "constraint"])
@parent(["_root", "ai_plugin"])
schema "ai_shared_folder" {
    path:           string @doc("Folder path.")
    description:    string @optional
    repository_ref: string @optional
}

@doc("A file within a shared AI folder.")
@children([])
@parent(["ai_shared_folder"])
schema "ai_shared_file" {
    path:        string @doc("File path relative to the folder.")
    content:     string @optional @doc("Inline file content.")
    description: string @optional
}

@doc("A Claude Code marketplace — a Git repository cataloging plugins.")
@children(["owner", "plugin_entry", "behaviour", "constraint"])
@parent(["_root"])
schema "ai_marketplace" {
    description:    string @optional
    version:        string @optional
    repository_ref: string @optional
}

@doc("The marketplace maintainer.")
@children([])
@parent(["ai_marketplace"])
schema "owner" {
    email: string @optional
}

@doc("A plugin entry in a marketplace.")
@children(["plugin_source", "author"])
@parent(["ai_marketplace"])
schema "plugin_entry" {
    source:      string @optional @doc("Relative path to the plugin.")
    version:     string @optional
    category:    string @optional
    strict:      bool   @optional @default(true)
    license:     string @optional
    description: string @optional
}

@doc("A structured source for fetching a plugin from an external location.")
@children([])
@parent(["plugin_entry"])
schema "plugin_source" {
    source_type: string @doc("Source type (github, url, npm, pip).")
    repo:        string @optional @doc("GitHub owner/repo.")
    git_ref:     string @optional @doc("Git ref (branch, tag, SHA).")
    url:         string @optional @doc("Git URL.")
    package:     string @optional @doc("Package name.")
}

@doc("The author of a plugin.")
@children([])
@parent(["ai_plugin", "plugin_entry"])
schema "author" {
    email: string @optional
    url:   string @optional
}

// ── Inside AISkill / AIAgent ────────────────────────────────────────────────

@doc("An activation trigger for a skill or agent.")
@children([])
@parent(["ai_skill", "ai_agent"])
schema "trigger" {
    description: string @optional
}

@doc("A tool the skill or agent is allowed to use.")
@children(["behaviour", "constraint"])
@parent(["ai_skill", "ai_agent", "agent"])
schema "tool" {
    description: string @optional
}

@doc("A typed input parameter for a skill or agent.")
@children(["behaviour", "constraint"])
@parent(["ai_skill", "ai_agent"])
schema "parameter" {
    param_type:  string @doc("Parameter type.")
    required:    bool   @optional @default(true)
    default:     string @optional
    description: string @optional
}

@doc("A typed output produced by a skill or agent.")
@children(["behaviour", "constraint"])
@parent(["ai_skill", "ai_agent"])
schema "output" {
    output_type: string @doc("Output type.")
    description: string @optional
}

@doc("The persistence layer for a skill or agent's state.")
@children(["behaviour", "constraint"])
@parent(["ai_skill", "ai_agent"])
schema "data_store" {
    description: string @optional
}

@doc("A subagent that a skill or agent can dispatch.")
@children(["tool", "behaviour", "constraint"])
@parent(["ai_skill", "ai_agent"])
schema "agent" {
    description: string @optional
}

@doc("A handler that executes when a hook fires.")
@children(["behaviour", "constraint"])
@parent(["ai_hook"])
schema "handler" {
    handler_type: string @doc("Handler type (command, prompt, agent).")
    command:      string @optional @doc("Shell command to execute.")
    prompt:       string @optional @doc("Prompt text.")
    timeout:      int    @optional @doc("Timeout in milliseconds.")
}
