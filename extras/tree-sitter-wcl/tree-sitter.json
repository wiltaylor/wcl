{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "wcl",
      "scope": "source.wcl",
      "path": ".",
      "file-types": [
        "wcl"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.0.0-local",
    "license": "MIT",
    "links": {
      "repository": "https://github.com/wiltaylor/wcl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}