<lexer>
  <config>
    <name>WCL</name>
    <alias>wcl</alias>
    <filename>*.wcl</filename>
    <mime_type>text/x-wcl</mime_type>
  </config>
  <rules>
    <state name="root">
      <!-- Comments -->
      <rule pattern="///.*$"><token type="CommentSpecial"/></rule>
      <rule pattern="//.*$"><token type="CommentSingle"/></rule>
      <rule pattern="/\*"><token type="CommentMultiline"/><push state="block_comment"/></rule>

      <!-- Whitespace -->
      <rule pattern="\s+"><token type="TextWhitespace"/></rule>

      <!-- Strings -->
      <rule pattern="&quot;"><token type="LiteralStringDouble"/><push state="string"/></rule>

      <!-- Heredocs -->
      <rule pattern="&lt;&lt;-?'?([a-zA-Z_]\w*)'?"><token type="LiteralStringHeredoc"/><push state="heredoc"/></rule>

      <!-- Numbers (order matters: floats before ints) -->
      <rule pattern="\b\d+\.\d+([eE][+-]?\d+)?\b"><token type="LiteralNumberFloat"/></rule>
      <rule pattern="\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\b"><token type="LiteralNumberHex"/></rule>
      <rule pattern="\b0[oO][0-7][0-7_]*\b"><token type="LiteralNumberOct"/></rule>
      <rule pattern="\b0[bB][01][01_]*\b"><token type="LiteralNumberBin"/></rule>
      <rule pattern="\b\d[0-9_]*\b"><token type="LiteralNumberInteger"/></rule>

      <!-- Decorators -->
      <rule pattern="(@)([a-zA-Z_]\w*)">
        <bygroups>
          <token type="Punctuation"/>
          <token type="NameDecorator"/>
        </bygroups>
      </rule>

      <!-- Control flow keywords -->
      <rule pattern="\b(if|else|for|in|when)\b"><token type="Keyword"/></rule>

      <!-- Declaration keywords -->
      <rule pattern="\b(let|partial|macro|schema|table|validation|decorator_schema|declare)\b"><token type="KeywordDeclaration"/></rule>

      <!-- Import/export -->
      <rule pattern="\b(import|export)\b"><token type="KeywordNamespace"/></rule>

      <!-- Other keywords -->
      <rule pattern="\b(inject|set|remove|check|message|target)\b"><token type="Keyword"/></rule>

      <!-- Built-in functions / query keywords -->
      <rule pattern="\b(query|has|import_table|import_raw|ref)\b"><token type="NameBuiltin"/></rule>

      <!-- Boolean / null constants -->
      <rule pattern="\b(true|false)\b"><token type="KeywordConstant"/></rule>
      <rule pattern="\bnull\b"><token type="KeywordConstant"/></rule>

      <!-- Type names -->
      <rule pattern="\b(string|int|float|bool|identifier|any)\b"><token type="KeywordType"/></rule>
      <rule pattern="\b(list|map|set|union|ref)\b(?=\s*\()"><token type="KeywordType"/></rule>

      <!-- Function calls (identifier followed by paren) -->
      <rule pattern="\b([a-zA-Z_]\w*)(\s*\()">
        <bygroups>
          <token type="NameFunction"/>
          <token type="Punctuation"/>
        </bygroups>
      </rule>

      <!-- Identifier literals (contain hyphens) -->
      <rule pattern="\b[a-zA-Z_]\w*-[\w-]*\b"><token type="NameLabel"/></rule>

      <!-- Plain identifiers -->
      <rule pattern="\b[a-zA-Z_]\w*\b"><token type="NameOther"/></rule>

      <!-- Multi-char operators -->
      <rule pattern="=&gt;|-&gt;|==|!=|&lt;=|&gt;=|=~|&amp;&amp;|\|\|"><token type="Operator"/></rule>

      <!-- Single-char operators -->
      <rule pattern="[+\-*/%=!&lt;&gt;|?:]"><token type="Operator"/></rule>

      <!-- Punctuation -->
      <rule pattern="[{}()\[\]]"><token type="Punctuation"/></rule>
      <rule pattern="[,.]"><token type="Punctuation"/></rule>

      <!-- Library imports -->
      <rule pattern="&lt;[^&gt;]+&gt;"><token type="LiteralStringOther"/></rule>
    </state>

    <state name="string">
      <rule pattern="&quot;"><token type="LiteralStringDouble"/><pop depth="1"/></rule>
      <rule pattern="\\[&quot;\\nrt/]"><token type="LiteralStringEscape"/></rule>
      <rule pattern="\\u[0-9a-fA-F]{4}"><token type="LiteralStringEscape"/></rule>
      <rule pattern="\\U[0-9a-fA-F]{8}"><token type="LiteralStringEscape"/></rule>
      <rule pattern="\$\{"><token type="LiteralStringInterpol"/><push state="interpolation"/></rule>
      <rule pattern="[^&quot;\\$]+"><token type="LiteralStringDouble"/></rule>
      <rule pattern="\$"><token type="LiteralStringDouble"/></rule>
    </state>

    <state name="interpolation">
      <rule pattern="\}"><token type="LiteralStringInterpol"/><pop depth="1"/></rule>
      <rule><include state="root"/></rule>
    </state>

    <state name="heredoc">
      <rule pattern="^[a-zA-Z_]\w*\s*$"><token type="LiteralStringHeredoc"/><pop depth="1"/></rule>
      <rule pattern="[^\n]+"><token type="LiteralStringHeredoc"/></rule>
      <rule pattern="\n"><token type="LiteralStringHeredoc"/></rule>
    </state>

    <state name="block_comment">
      <rule pattern="\*/"><token type="CommentMultiline"/><pop depth="1"/></rule>
      <rule pattern="/\*"><token type="CommentMultiline"/><push state="block_comment"/></rule>
      <rule pattern="[^/*]+"><token type="CommentMultiline"/></rule>
      <rule pattern="[/*]"><token type="CommentMultiline"/></rule>
    </state>
  </rules>
</lexer>
